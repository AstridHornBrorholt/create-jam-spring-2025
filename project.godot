;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Create Jam Spring 2025"
run/main_scene="uid://cx20x3knm431p"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://bwj40mov5jiam"

[autoload]

MainTickEvent="*res://Scripts/MainTickEvent.gd"
CurrentRun="*res://Scripts/RunState.gd"
Options="*res://Scripts/Options.gd"

[debug]

gdscript/warnings/unused_variable=0
gdscript/warnings/unused_local_constant=0
gdscript/warnings/shadowed_variable=0
gdscript/warnings/shadowed_global_identifier=0
gdscript/warnings/confusable_identifier=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/resizable=false
window/stretch/mode="viewport"

